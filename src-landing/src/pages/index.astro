---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { siteConfig } from "../config/site";

const features = [
  {
    title: "Dual Runtime",
    text: "Move between browser and desktop workflows without changing how you query, inspect, and iterate.",
  },
  {
    title: "Fast SQL Workbench",
    text: "Write, format, and run SQL with Monaco, schema browsing, and result grids designed for real throughput.",
  },
  {
    title: "Provider Ready",
    text: "Use modern hosted databases in web mode while desktop mode stays open for native drivers and private networks.",
  },
  {
    title: "Security-First UX",
    text: "Vault controls and local persistence scaffolding give teams a clear path to secure connection management.",
  },
];
---

<MarketingLayout
  title="Qwerio | SQL Workspace for Web and Desktop"
  canonicalPath="/"
>
  <SiteHeader />

  <main class="container home-main">
    <section class="hero panel">
      <p class="eyebrow">Dual-Mode Database Manager</p>
      <h1>One SQL workspace for browser velocity and desktop control.</h1>
      <p class="hero-copy">
        Qwerio gives engineering teams a focused query workbench that runs where you need it.
        Use web mode for fast collaboration or desktop mode for deeper local workflows.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary" href={siteConfig.webAppUrl} target="_blank" rel="noreferrer">
          Open Web App
        </a>
        <a class="btn" href={siteConfig.desktopAppUrl} target="_blank" rel="noreferrer">
          Get Desktop App
        </a>
      </div>
    </section>

    <section class="feature-grid" aria-label="Core product capabilities">
      {
        features.map((feature) => (
          <article class="feature-card panel-tight">
            <h2>{feature.title}</h2>
            <p>{feature.text}</p>
          </article>
        ))
      }
    </section>
  </main>

  <SiteFooter />
</MarketingLayout>
